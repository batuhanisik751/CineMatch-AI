# ============================================================
# CineMatch-AI Environment Configuration
# Copy to .env: cp .env.example .env
# Then update the REQUIRED section at the bottom
# ============================================================

# Embedding model (used for content similarity AND semantic "vibe" search)
CINEMATCH_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CINEMATCH_EMBEDDING_BATCH_SIZE=256

# FAISS index paths
CINEMATCH_FAISS_INDEX_PATH=data/processed/faiss.index
CINEMATCH_FAISS_ID_MAP_PATH=data/processed/faiss_id_map.pkl

# ALS collaborative filtering
CINEMATCH_ALS_MODEL_PATH=data/processed/als_model.pkl
CINEMATCH_ALS_USER_MAP_PATH=data/processed/als_user_map.pkl
CINEMATCH_ALS_ITEM_MAP_PATH=data/processed/als_item_map.pkl
CINEMATCH_ALS_USER_ITEMS_PATH=data/processed/als_user_items.npz

# Hybrid recommender (0.0 = pure collab, 1.0 = pure content)
CINEMATCH_HYBRID_ALPHA=0.5
# Default MMR diversity lambda (used when no per-request diversity level is specified)
# Users can override via ?diversity=low|medium|high (maps to 0.9 / 0.7 / 0.4)
CINEMATCH_HYBRID_DIVERSITY_LAMBDA=0.7
CINEMATCH_HYBRID_SEQUEL_PENALTY=0.5

# LLM (optional — choose "ollama" for local or "groq" for cloud)
# Option A: Local Ollama (install Ollama and run: ollama pull mistral)
#   CINEMATCH_LLM_BACKEND=ollama
#   CINEMATCH_LLM_MODEL_NAME=mistral
#   CINEMATCH_LLM_BASE_URL=http://localhost:11434
# Option B: Groq cloud (free tier — sign up at console.groq.com)
#   CINEMATCH_LLM_BACKEND=groq
#   CINEMATCH_LLM_MODEL_NAME=llama-3.1-8b-instant
#   CINEMATCH_LLM_BASE_URL=https://api.groq.com
#   CINEMATCH_LLM_API_KEY=gsk_your_key_here
CINEMATCH_LLM_ENABLED=true
CINEMATCH_LLM_BACKEND=ollama
CINEMATCH_LLM_MODEL_NAME=mistral
CINEMATCH_LLM_BASE_URL=http://localhost:11434
CINEMATCH_LLM_API_KEY=
CINEMATCH_LLM_RERANK_ENABLED=true
CINEMATCH_LLM_RERANK_TIMEOUT=60.0
CINEMATCH_LLM_RERANK_CANDIDATES=50

# Redis cache TTL
CINEMATCH_CACHE_TTL_SECONDS=3600

# Onboarding
CINEMATCH_ONBOARDING_THRESHOLD=10

# Import/Export
CINEMATCH_IMPORT_MAX_ROWS=10000
CINEMATCH_IMPORT_MAX_FILE_SIZE_MB=5

# Authentication (JWT)
CINEMATCH_JWT_ALGORITHM=HS256
CINEMATCH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API
CINEMATCH_API_HOST=0.0.0.0
CINEMATCH_API_PORT=8000
# Debug mode: enables Swagger UI (/docs), ReDoc (/redoc), and OpenAPI schema (/openapi.json)
# MUST be false in production to hide the API surface
CINEMATCH_DEBUG=false

# Domain (used by Caddy for TLS certificate provisioning)
# Set to your real domain in production, e.g.: CINEMATCH_DOMAIN=cinematch.example.com
CINEMATCH_DOMAIN=localhost

# CORS allowed origins (JSON list; defaults work for local dev)
# In production behind Caddy, same-origin means CORS is not needed — set to your domain
CINEMATCH_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# CORS allowed methods (JSON list; restrict in production)
CINEMATCH_CORS_METHODS=["GET","POST","PATCH","PUT","DELETE","OPTIONS"]
# CORS allowed headers (JSON list)
CINEMATCH_CORS_HEADERS=["Content-Type","Authorization"]

# Audit logging
CINEMATCH_AUDIT_LOG_FILE=logs/audit.log
CINEMATCH_AUDIT_LOG_ENABLED=true

# Dependency vulnerability scanning
# Timeout in seconds for each scanning tool (pip-audit, bandit, safety)
CINEMATCH_DEP_SCAN_TIMEOUT=120

# Rate limiting (format: "N/minute", "N/hour", etc.)
CINEMATCH_RATE_LIMIT_ENABLED=true
CINEMATCH_RATE_LIMIT_DEFAULT=100/minute
CINEMATCH_RATE_LIMIT_AUTH=5/minute
CINEMATCH_RATE_LIMIT_RECOMMENDATIONS=10/minute
CINEMATCH_RATE_LIMIT_SEARCH=30/minute
CINEMATCH_RATE_LIMIT_CSV_IMPORT=3/minute

# Database connection security
# SSL mode: "disable" (dev default), "prefer", "require" (recommended for prod), "verify-ca", "verify-full"
CINEMATCH_DATABASE_SSL_MODE=disable
# Statement timeout in ms (0 = no limit; 30000 = 30s recommended for production)
CINEMATCH_DATABASE_STATEMENT_TIMEOUT=30000
# Connection pool recycling in seconds (0 = disabled; 1800 = 30 min recommended)
CINEMATCH_DB_POOL_RECYCLE=1800
# Test connections before checkout (recommended: true)
CINEMATCH_DB_POOL_PRE_PING=true

# Security headers
CINEMATCH_HSTS_ENABLED=true
# Content-Security-Policy (tuned for Google Fonts + TMDB images + React inline styles)
# Override only if you add external CDNs or change frontend resource origins
CINEMATCH_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://image.tmdb.org data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Testing
# Tests override sensitive config via tests/conftest.py (dummy DB/Redis URLs, disabled rate limiting)
# Run: pytest tests/ -v

# Kaggle (required for TMDb dataset download)
# Get your token at https://www.kaggle.com/settings -> API -> Create New Token
# KAGGLE_API_TOKEN=your_token_here

# ============================================================
# REQUIRED — You MUST change these values
# The app will NOT start without them set in .env
# ============================================================

# Docker infrastructure passwords (used by docker-compose)
# In production, replace with strong random passwords
POSTGRES_PASSWORD=cinematch_dev
REDIS_PASSWORD=cinematch_dev

# Database (password must match POSTGRES_PASSWORD above)
CINEMATCH_DATABASE_URL=postgresql+asyncpg://cinematch:cinematch_dev@localhost:5432/cinematch
CINEMATCH_DATABASE_URL_SYNC=postgresql://cinematch:cinematch_dev@localhost:5432/cinematch

# Redis (password must match REDIS_PASSWORD above)
CINEMATCH_REDIS_URL=redis://:cinematch_dev@localhost:6379/0

# Authentication secret key
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
CINEMATCH_SECRET_KEY=dev-only-secret-change-in-production

# Limited-privilege database user (production only; created by docker init script)
# In production, replace with a strong random password
CINEMATCH_APP_DB_PASSWORD=cinematch_app_dev

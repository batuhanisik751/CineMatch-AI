# Database
CINEMATCH_DATABASE_URL=postgresql+asyncpg://cinematch:cinematch@localhost:5432/cinematch
CINEMATCH_DATABASE_URL_SYNC=postgresql://cinematch:cinematch@localhost:5432/cinematch

# Redis
CINEMATCH_REDIS_URL=redis://localhost:6379/0

# Embedding model
CINEMATCH_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CINEMATCH_EMBEDDING_BATCH_SIZE=256

# FAISS index paths
CINEMATCH_FAISS_INDEX_PATH=data/processed/faiss.index
CINEMATCH_FAISS_ID_MAP_PATH=data/processed/faiss_id_map.pkl

# ALS collaborative filtering
CINEMATCH_ALS_MODEL_PATH=data/processed/als_model.pkl
CINEMATCH_ALS_USER_MAP_PATH=data/processed/als_user_map.pkl
CINEMATCH_ALS_ITEM_MAP_PATH=data/processed/als_item_map.pkl
CINEMATCH_ALS_USER_ITEMS_PATH=data/processed/als_user_items.npz

# Hybrid recommender (0.0 = pure collab, 1.0 = pure content)
CINEMATCH_HYBRID_ALPHA=0.5

# LLM (optional -- set to true if you have Ollama + Mistral installed)
CINEMATCH_LLM_ENABLED=false

# API
CINEMATCH_DEBUG=false

# Kaggle (required for TMDb dataset download)
# Get your token at https://www.kaggle.com/settings -> API -> Create New Token
# KAGGLE_API_TOKEN=your_token_here

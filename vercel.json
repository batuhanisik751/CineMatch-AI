{
  "buildCommand": "pip install -e '.[lightweight]'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python",
      "maxDuration": 10
    }
  },
  "env": {
    "PYTHONPATH": "src"
  }
}

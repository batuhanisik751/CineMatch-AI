{$CINEMATCH_DOMAIN:localhost} {
    # API + backend routes → Uvicorn
    handle /api/* {
        reverse_proxy app:8000
    }
    handle /health {
        reverse_proxy app:8000
    }
    handle /docs {
        reverse_proxy app:8000
    }
    handle /openapi.json {
        reverse_proxy app:8000
    }
    handle /redoc {
        reverse_proxy app:8000
    }

    # Frontend SPA (React Router fallback)
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
